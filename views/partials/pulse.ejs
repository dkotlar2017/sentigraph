<style>

.pulse-wrapper {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: visible;
  z-index: -1; }

.pulse {
  position: absolute;
  left: calc(50% - 50px);
  top: calc(50% - 50px);
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: radial-gradient(circle at center, rgba(152, 104, 255, 0) 0, rgba(152, 104, 255, 0) 40%, #9868FF 100%);
  opacity: 0;
  animation: pulsate infinite 5s; }

@keyframes pulsate {
  0% {
    transform: scale(1);
    opacity: 0; }
  5% {
    opacity: .5; }
  100% {
    transform: scale(5);
    opacity: 0; } }

</style>

<div class="pulse-wrapper">
	<div key="0" class="pulse" style="animation-delay: 0s;"></div>
	<div key="1" class="pulse" style="animation-delay: 2s;"></div>
	<div key="2" class="pulse" style="animation-delay: 4s;"></div>
	<div key="3" class="pulse" style="animation-delay: 6s;"></div>
	<div key="4" class="pulse" style="animation-delay: 8s;"></div>
</div>

